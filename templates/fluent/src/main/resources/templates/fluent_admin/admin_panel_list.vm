<!DOCTYPE html>
<html lang="$lang" dir="$layout_direction">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>$pluralName - Admin</title>
    <link href="/static/fluent/css/fluent_common.css" rel="stylesheet">
    <link href="/static/fluent/css/fluent_layout.css" rel="stylesheet">
    <link href="/static/fluent/css/fluent_list.css" rel="stylesheet">
    #if($fontStylesheet) <link href="$fontStylesheet" rel="stylesheet"> #end
    #if($customCss) <style>$customCss</style> #end
    <link rel="icon" type="image/x-icon" href="/static/images/favicon.ico">
</head>
<body>
<div class="fluent-app">
    <form id="action-form" method="POST" style="display:none;"><input type="hidden" name="action_key" id="action-key"><input type="hidden" name="ids" id="ids"><input type="hidden" value="$csrfToken" name="_csrf"></form>
    <nav class="fluent-sidebar" id="fluent-sidebar">
        <div class="fluent-sidebar-header">
            <span class="fluent-sidebar-logo">
                #if($headerContentType == "image") <img src="$headerImageUrl" alt="$headerImageAlt" style="height: $headerImageHeight;"> #elseif($headerContentType == "text") <span style="font-weight:700;">$headerTextPrefix</span>$headerTextContent #end
            </span>
        </div>
        <div class="fluent-sidebar-nav">
            <a href="/$adminPath" class="fluent-nav-item">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 6L8 2L14 6V13C14 13.55 13.55 14 13 14H3C2.45 14 2 13.55 2 13V6Z" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round"/><path d="M6 14V9H10V14" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round"/></svg>
                <span class="fluent-nav-label">$translations['dashboard']</span>
            </a>
            #foreach($group in $panelGroups)
                <div class="fluent-nav-group-label">$group.group</div>
                #foreach($panel in $group.panels)
                    #set($capitalizedPanel = $panel.pluralName.substring(0,1).toUpperCase() + $panel.pluralName.substring(1))
                    <a href="/$adminPath/resources/$panel.pluralName" class="fluent-nav-item #if($panel.pluralName == $currentPanel) active #end">
                        #if($panel.iconFile) <div class="fluent-nav-item-icon-mask" style="-webkit-mask: url('$panel.iconFile') no-repeat center / contain; mask: url('$panel.iconFile') no-repeat center / contain;"></div> #else <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="2" y="2" width="12" height="12" rx="2" stroke="currentColor" stroke-width="1.25"/></svg> #end
                        <span class="fluent-nav-label">$capitalizedPanel</span>
                        #if($panel.tableName) #set($panelName = $panel.tableName) #else #set($panelName = $panel.collectionName) #end
                        #if($counts[$panelName]) <span class="fluent-nav-count">$counts[$panelName]</span> #end
                    </a>
                #end
            #end
        </div>
    </nav>

    <div class="fluent-main" id="fluent-main">
        <header class="fluent-topbar">
            <div class="fluent-topbar-left">
                <button class="fluent-topbar-toggle" onclick="toggleSidebar()"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M3 5H17M3 10H17M3 15H17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></button>
                #if($hasSearch)
                <div class="fluent-search-box">
                    <svg viewBox="0 0 16 16" fill="none"><path d="M7 12C9.76 12 12 9.76 12 7C12 4.24 9.76 2 7 2C4.24 2 2 4.24 2 7C2 9.76 4.24 12 7 12Z" stroke="currentColor" stroke-width="1.25"/><path d="M11 11L14 14" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/></svg>
                    <input class="fluent-search-input" type="search" placeholder="$translations['search']">
                </div>
                #end
            </div>
            <div class="fluent-topbar-center"></div>
            <div class="fluent-topbar-right">
                <div class="fluent-topbar-user">
                    <span class="fluent-topbar-username">$!username</span>
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2.5 4.5L6 8L9.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    <div class="fluent-user-dropdown">
                        #foreach($menu in $menus) <button class="fluent-dropdown-item"><a href="$menu.link">$menu.title</a></button> #end
                        <div class="fluent-dropdown-divider"></div>
                        #if($translators) <div class="fluent-submenu-container"><button class="fluent-dropdown-item" style="justify-content:space-between;">$translations['languages'] <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M4.5 2.5L8 6L4.5 9.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></button><div class="fluent-submenu">#foreach($translator in $translators) <button class="fluent-dropdown-item #if($current_lang == $translator.languageCode) fluent-selected-lang #end" onclick="changeLanguage('$translator.languageCode')">$translator.languageName</button> #end</div></div> #end
                        <button class="fluent-dropdown-item" onclick="changeTheme()">$translations['change_theme']</button>
                        #if($canDownload) <button class="fluent-dropdown-item" onclick="downloadFile('$pluralNameBase', '$csrfToken')">$translations['download_as_csv']</button> #end
                        #if($hasAuthenticate) <div class="fluent-dropdown-divider"></div> <button class="fluent-dropdown-item danger" onclick="logout()">$translations['logout']</button> #end
                    </div>
                </div>
            </div>
        </header>

        <div class="fluent-content">
            #if($filtersData.size != 0)
            <div class="fluent-filters-panel" id="filters-container">
                <div class="fluent-filters-grid">
                    #foreach($filter in $filtersData)
                        #if($filter.type == "DATE")
                            <div class="fluent-filter-group filter"><label class="fluent-filter-label">$translations['select_range_of'].replace('{value}', $filter.verboseName)</label><div class="fluent-filter-date-group"><input type="date" class="fluent-input" id="${filter.paramName}-start" name="${filter.paramName}"><input type="date" class="fluent-input" id="${filter.paramName}-end" name="${filter.paramName}"></div></div>
                        #elseif($filter.type == "DATETIME")
                            <div class="fluent-filter-group filter"><label class="fluent-filter-label">$translations['select_range_of'].replace('{value}', $filter.verboseName)</label><div class="fluent-filter-date-group"><input type="datetime-local" class="fluent-input" id="${filter.paramName}-start" name="${filter.paramName}"><input type="datetime-local" class="fluent-input" id="${filter.paramName}-end" name="${filter.paramName}"></div></div>
                        #elseif($filter.type == "ENUMERATION")
                            <div class="fluent-filter-group filter"><label class="fluent-filter-label">$translations['select_item_for'].replace('{value}', $filter.verboseName)</label><select class="fluent-select" name="${filter.paramName}" id="${filter.paramName}"><option value="">-- Select --</option>#foreach($value in $filter.values)<option value="${value}">${value}</option>#end</select></div>
                        #elseif($filter.type == "REFERENCE")
                            <div class="fluent-filter-group filter"><label class="fluent-filter-label">$translations['select_item_for'].replace('{value}', $filter.verboseName)</label><select class="fluent-select" name="${filter.paramName}" id="${filter.paramName}"><option value="">-- Select --</option>#foreach($item in $filter.values)<option value="${item.itemKey}">${item.item}</option>#end</select></div>
                        #elseif($filter.type == "BOOLEAN")
                            <div class="fluent-filter-group filter"><label class="fluent-filter-label">$translations['select_boolean'].replace('{value}', $filter.verboseName)</label><select class="fluent-select" name="${filter.paramName}" id="${filter.paramName}"><option value="">-- Select --</option><option value="on">True</option><option value="off">False</option></select></div>
                        #end
                    #end
                </div>
                <div style="margin-top:16px;"><button class="fluent-button fluent-button-primary" onclick="onFilterApply()">$translations['filter']</button></div>
            </div>
            #end

            <div class="fluent-actions-bar">
                <div class="fluent-page-header" style="flex:1;margin-bottom:0;">
                    <div style="display:flex;align-items:center;gap:12px;"><h1 class="fluent-page-title">$pluralName</h1><span class="fluent-page-count">$count_text</span></div>
                </div>
                <div style="display:flex;align-items:center;gap:8px;">
                    <select class="fluent-select actions-input" style="min-width:160px;"><option value="">$translations['select_action']</option>#foreach($action in $actions)<option value="${action.key}">${action.displayText}</option>#end</select>
                    <button class="fluent-button fluent-button-primary" onclick="openActionDialog()">$translations['perform']</button>
                    #if($filtersData.size != 0) <button class="fluent-button fluent-button-subtle" onclick="toggleFilter()"><svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M2 4H14M4 8H12M6 12H10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg> $translations['filter']</button> #end
                    <button class="fluent-button fluent-button-primary" onclick="window.location.href = cleanUrl().toString() + '/add'"><svg width="10" height="10" viewBox="0 0 12 12" fill="none"><path d="M6 1V11M1 6H11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg> Add</button>
                </div>
            </div>

            <div class="fluent-table-wrapper">
                <div class="fluent-table-scroll">
                    <table class="fluent-table-full">
                        <thead><tr>
                            <th data-col="checkbox"><div class="fluent-table-checkbox"><input type="checkbox" onchange="document.querySelectorAll('.select-field-checkbox').forEach(cb => cb.checked = this.checked)"></div></th>
                            #foreach($field in $fields)
                                #if($field.columnName) #set($name = $field.columnName) #else #set($name = $field.fieldName) #end
                                <th #if($field.type.name == "BOOLEAN") data-col="checkbox" #end onclick="handleSortClick('$name', '$!order.name', '$order.direction')">
                                    <div class="fluent-th-content">
                                        #if($!field.reference)<span style="opacity:.5;">#</span>#end$field.verboseName
                                        #if($!order.direction == "asc" and $!order.name == $name) <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2.5 8L6 4.5L9.5 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                        #elseif($!order.direction == "desc" and $!order.name == $name) <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2.5 4L6 7.5L9.5 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                        #end
                                    </div>
                                </th>
                            #end
                        </tr></thead>
                        <tbody>
                            #foreach($row in $rows)
                            <tr class="row" data-primary-key="$row.primaryKey">
                                <td data-col="checkbox"><div class="fluent-table-checkbox"><input type="checkbox" class="select-field-checkbox" data-primary-key="$row.primaryKey"></div></td>
                                #foreach($item in $row.data)
                                    #set($field = $fields.get($foreach.index))
                                    #if($field.type.name == "BOOLEAN")
                                        <td data-col="checkbox"><div class="fluent-table-checkbox"><input type="checkbox" #if($item == "true" || $item == "1") checked #end disabled></div></td>
                                    #elseif($field.type.name == "FILE" and $item and $item != "N/A")
                                        #if($field.columnName) #set($fieldName = $field.columnName) #else #set($fieldName = $field.fieldName) #end
                                        <td><a href="javascript:void(0)" class="fluent-link" onclick="generateUrl('$item', '$pluralNameBase', '$fieldName')">$translations['link']</a></td>
                                    #elseif($!field.reference and $!item.value)
                                        <td><a href="javascript:void(0)" class="fluent-link ref-link" onclick="redirectToEditWithPluralName('$item.pluralName', '$item.value')">$item.value</a></td>
                                    #elseif($field.type.name == "ENUMERATION" and $field.statusColors)
                                        #foreach($enumItem in $field.enumerationValues) #if($enumItem == $!item) #set($color = $field.statusColors.get($foreach.index)) #end #end
                                        <td><span class="fluent-status-badge" style="border-color:$color;color:$color;"><span class="fluent-status-dot" style="background-color:$color;"></span>$!item</span></td>
                                    #else
                                        <td><span class="item-text">$!item</span></td>
                                    #end
                                #end
                            </tr>
                            #end
                        </tbody>
                    </table>
                </div>
                <div class="fluent-pagination">
                    #set($prevPage = $currentPage - 1) #set($nextPage = $currentPage + 1)
                    #if($prevPage > 1) <button class="fluent-page-btn" onclick="redirectToPage(1)">1</button> <span class="fluent-page-dots">...</span> #end
                    #if($prevPage > 0) <button class="fluent-page-btn" onclick="redirectToPage($prevPage)">$prevPage</button> #end
                    <button class="fluent-page-btn active">$currentPage</button>
                    #if($nextPage <= $maxPages) <button class="fluent-page-btn" onclick="redirectToPage($nextPage)">$nextPage</button> #end
                    #if($nextPage < $maxPages) <span class="fluent-page-dots">...</span> <button class="fluent-page-btn" onclick="redirectToPage($maxPages)">$maxPages</button> #end
                </div>
            </div>
        </div>
    </div>
</div>
<div id="loading"><div class="spinner"></div></div>
<div class="fluent-overlay" id="dialog">
    <div class="fluent-dialog">
        <h2 class="fluent-dialog-title" id="action-dialog-title">Delete all items</h2>
        <p class="fluent-dialog-body">By confirming this action, you acknowledge that it is irreversible and cannot be undone.</p>
        <div class="fluent-dialog-actions">
            <button class="fluent-button fluent-button-subtle" onclick="closeActionDialog()">Cancel</button>
            <button class="fluent-button fluent-button-danger" onclick="performSelectedAction('$pluralNameBase')">Confirm</button>
        </div>
    </div>
</div>
<script>const adminPath = "$adminPath";</script>
<script src="/static/fluent/js/fluent_common.js"></script>
<script src="/static/fluent/js/fluent_table_list.js"></script>
<script>function toggleSidebar() { document.getElementById('fluent-sidebar').classList.toggle('collapsed'); document.getElementById('fluent-main').classList.toggle('sidebar-collapsed'); }</script>
</body>
</html>
