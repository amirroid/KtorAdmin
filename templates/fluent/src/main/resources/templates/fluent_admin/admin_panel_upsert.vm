<!DOCTYPE html>
<html lang="$lang" dir="$layout_direction">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    #if($title) <title>$title</title> #elseif($isUpdate) <title>Update $singularTableName</title> #else <title>Add a new $singularTableName</title> #end
    <link href="/static/fluent/css/fluent_common.css" rel="stylesheet">
    <link href="/static/fluent/css/fluent_layout.css" rel="stylesheet">
    <link href="/static/fluent/css/fluent_upsert.css" rel="stylesheet">
    <link href="/static/fluent/css/fluent_autocomplete.css" rel="stylesheet">
    #if($fontStylesheet) <link href="$fontStylesheet" rel="stylesheet"> #end
    #if($customCss) <style>$customCss</style> #end
    #if($tinyMCEConfig) <script src="https://cdnjs.cloudflare.com/ajax/libs/tinymce/6.7.1/tinymce.min.js"></script> #end
    <link rel="icon" type="image/x-icon" href="/static/images/favicon.ico">
</head>
<body>
<form id="action-form" method="POST" style="display:none;"><input type="hidden" name="action_key" id="action-key"><input type="hidden" name="ids" id="ids"><input type="hidden" value="$csrfToken" name="_csrf"></form>
<div class="fluent-app">
    <nav class="fluent-sidebar" id="fluent-sidebar">
        <div class="fluent-sidebar-header"><span class="fluent-sidebar-logo">#if($headerContentType == "image") <img src="$headerImageUrl" alt="$headerImageAlt" style="height: $headerImageHeight;"> #elseif($headerContentType == "text") <span style="font-weight:700;">$headerTextPrefix</span>$headerTextContent #end</span></div>
        <div class="fluent-sidebar-nav">
            <a href="/$adminPath" class="fluent-nav-item"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 6L8 2L14 6V13C14 13.55 13.55 14 13 14H3C2.45 14 2 13.55 2 13V6Z" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round"/><path d="M6 14V9H10V14" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round"/></svg><span class="fluent-nav-label">$translations['dashboard']</span></a>
            #foreach($group in $panelGroups) <div class="fluent-nav-group-label">$group.group</div> #foreach($panel in $group.panels) #set($capitalizedPanel = $panel.pluralName.substring(0,1).toUpperCase() + $panel.pluralName.substring(1)) <a href="/$adminPath/resources/$panel.pluralName" class="fluent-nav-item #if($panel.pluralName == $currentPanel) active #end">#if($panel.iconFile) <div class="fluent-nav-item-icon-mask" style="-webkit-mask: url('$panel.iconFile') no-repeat center / contain; mask: url('$panel.iconFile') no-repeat center / contain;"></div> #else <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="2" y="2" width="12" height="12" rx="2" stroke="currentColor" stroke-width="1.25"/></svg> #end<span class="fluent-nav-label">$capitalizedPanel</span>#if($panel.tableName) #set($panelName = $panel.tableName) #else #set($panelName = $panel.collectionName) #end#if($counts[$panelName]) <span class="fluent-nav-count">$counts[$panelName]</span> #end</a> #end #end
            #if($customPageGroups) #foreach($pageGroup in $customPageGroups) <div class="fluent-nav-group-label">$pageGroup.group</div> #foreach($page in $pageGroup.pages) <a href="/$adminPath/resources/$page.path" class="fluent-nav-item #if($page.path == $currentPagePath) active #end">#if($page.icon) <div class="fluent-nav-item-icon-mask" style="-webkit-mask: url('$page.icon') no-repeat center / contain; mask: url('$page.icon') no-repeat center / contain;"></div> #else <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="2" y="2" width="12" height="12" rx="2" stroke="currentColor" stroke-width="1.25"/></svg> #end<span class="fluent-nav-label">$page.title</span></a> #end #end #end
        </div>
    </nav>
    <div class="fluent-main" id="fluent-main">
        <header class="fluent-topbar">
            <div class="fluent-topbar-left"><button class="fluent-topbar-toggle" onclick="toggleSidebar()"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M3 5H17M3 10H17M3 15H17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></button></div>
            <div class="fluent-topbar-center"></div>
            <div class="fluent-topbar-right"><div class="fluent-topbar-user"><span class="fluent-topbar-username">$!username</span><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2.5 4.5L6 8L9.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg><div class="fluent-user-dropdown">#foreach($menu in $menus) <button class="fluent-dropdown-item"><a href="$menu.link">$menu.title</a></button> #end<div class="fluent-dropdown-divider"></div>#if($translators) <div class="fluent-submenu-container"><button class="fluent-dropdown-item" style="justify-content:space-between;">$translations['languages'] <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M4.5 2.5L8 6L4.5 9.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></button><div class="fluent-submenu">#foreach($translator in $translators) <button class="fluent-dropdown-item #if($current_lang == $translator.languageCode) fluent-selected-lang #end" onclick="changeLanguage('$translator.languageCode')">$translator.languageName</button> #end</div></div> #end<button class="fluent-dropdown-item" onclick="changeTheme()">$translations['change_theme']</button>#if($canDownload) <button class="fluent-dropdown-item" onclick="downloadFile('$pluralNameBase', '$csrfToken', '$primaryKey')">$translations['download_as_pdf']</button> #end#if($hasAuthenticate) <div class="fluent-dropdown-divider"></div><button class="fluent-dropdown-item danger" onclick="logout()">$translations['logout']</button> #end</div></div></div>
        </header>
        <div class="fluent-content">
            <div class="fluent-page-header">
                #if($title) <h1 class="fluent-page-title">$title</h1> #elseif($isUpdate) <h1 class="fluent-page-title">Update $singularTableName</h1> #else <h1 class="fluent-page-title">Add a new $singularTableName</h1> #end
                <a href="javascript:history.back()" class="fluent-button fluent-button-subtle"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M7.5 2.5L3.5 6L7.5 9.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg> Back</a>
            </div>
            <div class="fluent-card" style="max-width:800px;">
                <form method="post" #if($callMethod) enctype="$callMethod" #else enctype="multipart/form-data" #end id="form-box" class="fluent-upsert-form">
                    #foreach($column in $columns)
                        <div class="fluent-form-field">
                            #if($!values.get($column.columnName)) #set($defaultValue = $values.get($column.columnName)) #elseif($column.defaultValue) #set($defaultValue = $column.defaultValue) #else #set($defaultValue = "") #end
                            #if($column.type.name != "BOOLEAN") <label class="fluent-form-label #if($column.readOnly) fluent-form-label-disabled #end">$column.verboseName</label> #end
                            #if($column.reference)
                                #set($referenceValues = $references.get($column))
                                #if($column.hasAutoComplete) <input type="hidden" name="$column.columnName" value="$!defaultValue" id="hidden-$column.columnName"><input type="text" class="fluent-input" value="$!defaultValue" data-autocomplete data-autocomplete-table="$tableName" data-autocomplete-column="$column.columnName" data-autocomplete-admin-path="$adminPath" #if($column.readOnly)readonly#end placeholder="$translations['select_item']">
                                #elseif($column.reference.type == "select") <select name="$column.columnName" class="fluent-select" #if($column.readOnly)disabled#end><option value="">$translations['select_item']</option>#foreach($refValue in $referenceValues)<option value="$refValue.itemKey" #if($refValue.itemKey == $!defaultValue)selected#end>$refValue.item</option>#end</select>
                                #elseif($column.reference.type == "list") #set($list_selected = $selectedReferences.get($column)) <select class="fluent-select fluent-select-multiple" name="$column.columnName" multiple #if($column.readOnly) disabled #end>#foreach($refValue in $referenceValues)<option value="$refValue.itemKey" #if($list_selected && $list_selected[$refValue.itemKey]) selected #end>$refValue.item</option>#end</select>
                                #end
                            #elseif($column.hasConfirmation and $isUpdate)
                                #if($defaultValue) <p class="fluent-confirmation-value">Current value: $!defaultValue</p> #end
                                #set($reset_text = $translations.get('reset_item').replace("{name}", $column.verboseName))
                                <button type="button" class="fluent-button fluent-button-subtle fluent-confirmation-btn" onclick="goToConfigurationEditUrl('$column.columnName')">$reset_text</button>
                            #else
                                #if($column.type.name == "STRING")
                                    #if($column.hasRichEditor) <textarea name="$column.columnName" class="fluent-textarea rich-editor-area" #if($column.readOnly)readonly#end>$!defaultValue</textarea>
                                    #elseif($column.hasTextArea) <textarea name="$column.columnName" class="fluent-textarea" #if($column.readOnly)readonly#end>$!defaultValue</textarea>
                                    #else <input type=#if($column.hasConfirmation) "password" #else "text" #end class="fluent-input" name="$column.columnName" value="$!defaultValue" #if($column.readOnly)readonly#end/>
                                    #end
                                #end
                                #if($column.type.name == "INTEGER" || $column.type.name == "UINTEGER") <input type="number" class="fluent-input" name="$column.columnName" value="$!defaultValue" #if($column.readOnly)readonly#end/> #end
                                #if($column.type.name == "SHORT" || $column.type.name == "USHORT") <input type="number" class="fluent-input" name="$column.columnName" value="$!defaultValue" #if($column.readOnly)readonly#end/> #end
                                #if($column.type.name == "LONG" || $column.type.name == "ULONG") <input type="number" class="fluent-input" name="$column.columnName" value="$!defaultValue" #if($column.readOnly)readonly#end/> #end
                                #if($column.type.name == "DOUBLE") <input type="number" step="any" class="fluent-input" name="$column.columnName" value="$!defaultValue" #if($column.readOnly)readonly#end/> #end
                                #if($column.type.name == "FLOAT") <input type="number" step="any" class="fluent-input" name="$column.columnName" value="$!defaultValue" #if($column.readOnly)readonly#end/> #end
                                #if($column.type.name == "BIG_DECIMAL") <input type="text" class="fluent-input" name="$column.columnName" value="$!defaultValue" #if($column.readOnly)readonly#end/> #end
                                #if($column.type.name == "CHAR") <input type="text" maxlength="1" class="fluent-input" name="$column.columnName" value="$!defaultValue" #if($column.readOnly)readonly#end/> #end
                                #if($column.type.name == "UUID") <input type="text" class="fluent-input" name="$column.columnName" value="$!defaultValue" #if($column.readOnly)readonly#end/> #end
                                #if($column.type.name == "BOOLEAN") <label class="fluent-checkbox">#if($column.nullable == false) <input type="hidden" name="${column.columnName}" value="off"> #end<input type="checkbox" name="${column.columnName}" #if($!defaultValue == "true" || $!defaultValue == "1" || $!defaultValue == "on") checked #end #if($column.readOnly) disabled #end><span class="fluent-checkbox-label">$column.verboseName</span></label> #end
                                #if($column.type.name == "ENUMERATION") <select name="$column.columnName" class="fluent-select" #if($column.readOnly)disabled#end><option value="">$translations['select_item']</option>#foreach($value in $column.enumerationValues)<option value="$value" #if($value == $!defaultValue)selected#end>$value</option>#end</select> #end
                                #if($column.type.name == "DATE") <input type="date" class="fluent-input" name="$column.columnName" value="$!defaultValue" #if($column.readOnly)readonly#end/> #end
                                #if($column.type.name == "DATETIME" || $column.type.name == "TIMESTAMP_WITH_TIMEZONE") <input type="datetime-local" class="fluent-input" name="$column.columnName" value="$!defaultValue" #if($column.readOnly)readonly#end/> #end
                                #if($column.type.name == "BINARY") <label for="$column.columnName" class="fluent-file-input-label #if($column.readOnly) fluent-readonly #end">$translations['select_file']</label><input type="file" class="fluent-file-input-field" name="$column.columnName" id="$column.columnName" #if($column.readOnly)disabled#end/><p class="fluent-file-label" id="selected-file-$column.columnName"></p> #end
                                #if($column.type.name == "FILE") <label for="$column.columnName" class="fluent-file-input-label #if($column.readOnly) fluent-readonly #end">$translations['select_file']</label><input type="file" class="fluent-file-input-field" name="$column.columnName" id="$column.columnName" #if($column.readOnly)disabled#end/><p class="fluent-file-label" id="selected-file-$column.columnName"></p>#if($!values.get($column.columnName)) <a href="javascript:void(0)" class="fluent-file-link" onclick="openFileLink('$!values.get($column.columnName)')">$translations['current_file'] <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M5 2H3C2.45 2 2 2.45 2 3V9C2 9.55 2.45 10 3 10H9C9.55 10 10 9.55 10 9V7M6.5 2.5L10 2.5L10 6M10 2.5L5.5 7" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/></svg></a> #end #end
                            #end
                            #if($!errors.get($column.columnName)) <div class="fluent-form-error">#foreach($error in $errors.get($column.columnName).messages) $error<br/>#end</div> #end
                        </div>
                        #set($previewItem = $previews[$column]) #if($previewItem) $previewItem #end
                    #end
                    <input type="hidden" value="$csrfToken" name="_csrf">
                    <input type="hidden" value="$requestId" name="requestId">
                    <div style="display:flex;gap:8px;margin-top:8px;">
                        <button id="submit-button" type="submit" class="fluent-button fluent-button-primary #if($hasAction == false) disabled #end" style="height:36px;padding:0 20px;">$translations['submit']</button>
                        <a href="javascript:history.back()" class="fluent-button fluent-button-subtle" style="height:36px;">Cancel</a>
                    </div>
                </form>
                #if($isUpdate && $actions && $actions.size() > 0)
                    <div class="fluent-edit-actions">
                        <div class="fluent-edit-actions-header">
                            $translations['actions']
                        </div>
                        <div class="fluent-edit-actions-grid">
                            #foreach($action in $actions)
                                #if($action.options.showInEditPage)
                                    <button class="fluent-button fluent-button-subtle"
                                            onclick="openEditActionDialog('$action.key', '$action.displayText')"
                                            #if($action.options.style) style="$action.options.style" #end>
                                        #if($action.options.icon) $action.options.icon #end
                                        $action.displayText
                                    </button>
                                #end
                            #end
                        </div>
                    </div>
                #end
            </div>
        </div>
    </div>
</div>
<div class="fluent-overlay" id="edit-action-dialog"
     data-title="$translations['confirm_action_title']"
     data-message="$translations['confirm_action_message']">
    <div class="fluent-dialog">
        <h2 class="fluent-dialog-title" id="edit-action-dialog-title"></h2>
        <p class="fluent-dialog-body" id="edit-action-dialog-message"></p>
        <div class="fluent-dialog-actions">
            <button class="fluent-button fluent-button-subtle" onclick="closeEditActionDialog()">$translations['cancel']</button>
            <button class="fluent-button fluent-button-danger" onclick="performEditAction()">$translations['confirm']</button>
        </div>
    </div>
</div>
<div id="loading"><div class="spinner"></div></div>
<script>const selectedFileText = "$translations['selected_file']"; const adminPath = "$adminPath"; #if($isUpdate) const editPrimaryKey = "$primaryKey"; const editPluralName = "$pluralNameBase"; #end #if($tinyMCEConfig) const tinyConfig = JSON.parse(`$tinyMCEConfig`); #end const computedColumns = []; #foreach($column in $columns) #if($column.computedColumn) computedColumns.push({ columnName: "$column.columnName", computedColumn: "$column.computedColumn" }); #end #end</script>
<script src="/static/fluent/js/fluent_common.js"></script>
<script src="/static/js/autocomplete.js"></script>
<script src="/static/fluent/js/fluent_upsert.js"></script>
</body>
</html>
