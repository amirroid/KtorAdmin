<!DOCTYPE html>
<html lang="$lang" dir="$layout_direction">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>$pageTitle</title>
    <link href="/static/fluent/css/fluent_common.css" rel="stylesheet">
    <link href="/static/fluent/css/fluent_layout.css" rel="stylesheet">
    #if($fontStylesheet) <link href="$fontStylesheet" rel="stylesheet"> #end
    #if($customCss) <style>$customCss</style> #end
    <link rel="icon" type="image/x-icon" href="/static/images/favicon.ico">
</head>
<body>
<div class="fluent-app">
    <nav class="fluent-sidebar" id="fluent-sidebar">
        <div class="fluent-sidebar-header">
            <span class="fluent-sidebar-logo">
                #if($headerContentType == "image")
                    <img src="$headerImageUrl" alt="$headerImageAlt" style="height: $headerImageHeight;">
                #elseif($headerContentType == "text")
                    <span style="font-weight:700;">$headerTextPrefix</span>$headerTextContent
                #end
            </span>
        </div>
        <div class="fluent-sidebar-nav">
            #if($dashboardGroups)
                #foreach($dashboardGroup in $dashboardGroups)
                    #if($dashboardGroup.entries.size > 1 || $dashboardGroup.entries[0].groupName)
                        <div class="fluent-nav-group-label">$dashboardGroup.group</div>
                    #end
                    #foreach($entry in $dashboardGroup.entries)
                        <a href="/$adminPath/resources/$entry.path" class="fluent-nav-item #if($entry.path == $currentPagePath) active #end">
                            #if($entry.icon)
                                <div class="fluent-nav-item-icon-mask" style="-webkit-mask: url('$entry.icon') no-repeat center / contain; mask: url('$entry.icon') no-repeat center / contain;"></div>
                            #end
                            <span class="fluent-nav-label">$entry.title</span>
                        </a>
                    #end
                #end
            #else
                <a href="/$adminPath" class="fluent-nav-item">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 6L8 2L14 6V13C14 13.55 13.55 14 13 14H3C2.45 14 2 13.55 2 13V6Z" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round"/><path d="M6 14V9H10V14" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round"/></svg>
                    <span class="fluent-nav-label">$translations['dashboard']</span>
                </a>
            #end
            #foreach($group in $panelGroups)
                <div class="fluent-nav-group-label">$group.group</div>
                #foreach($panel in $group.panels)
                    #set($capitalizedPanel = $panel.pluralName.substring(0,1).toUpperCase() + $panel.pluralName.substring(1))
                    <a href="/$adminPath/resources/$panel.pluralName" class="fluent-nav-item">
                        #if($panel.iconFile)
                            <div class="fluent-nav-item-icon-mask" style="-webkit-mask: url('$panel.iconFile') no-repeat center / contain; mask: url('$panel.iconFile') no-repeat center / contain;"></div>
                        #else
                            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="2" y="2" width="12" height="12" rx="2" stroke="currentColor" stroke-width="1.25"/></svg>
                        #end
                        <span class="fluent-nav-label">$capitalizedPanel</span>
                        #if($panel.tableName) #set($panelName = $panel.tableName) #else #set($panelName = $panel.collectionName) #end
                        #if($counts[$panelName]) <span class="fluent-nav-count">$counts[$panelName]</span> #end
                    </a>
                #end
            #end
            #if($customPageGroups)
                #foreach($pageGroup in $customPageGroups)
                    <div class="fluent-nav-group-label">$pageGroup.group</div>
                    #foreach($page in $pageGroup.pages)
                        <a href="/$adminPath/resources/$page.path" class="fluent-nav-item #if($page.path == $currentPagePath) active #end">
                            #if($page.icon)
                                <div class="fluent-nav-item-icon-mask" style="-webkit-mask: url('$page.icon') no-repeat center / contain; mask: url('$page.icon') no-repeat center / contain;"></div>
                            #else
                                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="2" y="2" width="12" height="12" rx="2" stroke="currentColor" stroke-width="1.25"/></svg>
                            #end
                            <span class="fluent-nav-label">$page.title</span>
                        </a>
                    #end
                #end
            #end
        </div>
    </nav>

    <div class="fluent-main" id="fluent-main">
        <header class="fluent-topbar">
            <div class="fluent-topbar-left">
                <button class="fluent-topbar-toggle" onclick="toggleSidebar()">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M3 5H17M3 10H17M3 15H17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                </button>
            </div>
            <div class="fluent-topbar-center"></div>
            <div class="fluent-topbar-right">
                <div class="fluent-topbar-user">
                    <span class="fluent-topbar-username">$!username</span>
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2.5 4.5L6 8L9.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    <div class="fluent-user-dropdown">
                        #foreach($menu in $menus) <button class="fluent-dropdown-item"><a href="$menu.link">$menu.title</a></button> #end
                        <div class="fluent-dropdown-divider"></div>
                        #if($translators)
                            <div class="fluent-submenu-container">
                                <button class="fluent-dropdown-item" style="justify-content:space-between;">$translations['languages'] <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M4.5 2.5L8 6L4.5 9.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
                                <div class="fluent-submenu">
                                    #foreach($translator in $translators) <button class="fluent-dropdown-item #if($current_lang == $translator.languageCode) fluent-selected-lang #end" onclick="changeLanguage('$translator.languageCode')">$translator.languageName</button> #end
                                </div>
                            </div>
                        #end
                        <button class="fluent-dropdown-item" onclick="changeTheme()">$translations['change_theme']</button>
                        #if($hasAuthenticate) <div class="fluent-dropdown-divider"></div> <button class="fluent-dropdown-item danger" onclick="logout()">$translations['logout']</button> #end
                    </div>
                </div>
            </div>
        </header>

        <div class="fluent-content">
            <div class="fluent-page-header">
                <h1 class="fluent-page-title">$pageTitle</h1>
            </div>
            <div style="padding:0;">
                $pageContent
            </div>
        </div>
    </div>
</div>
<script src="/static/fluent/js/fluent_common.js"></script>
<script>
    const adminPath = "$adminPath"
</script>
</body>
</html>
